# MedGemma Medical AI — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to git (it is in .gitignore).

# ── HuggingFace ──────────────────────────────────────────────────────────────
# Required to download HAI-DEF model weights.
# Get token at: https://huggingface.co/settings/tokens
# Accept model terms at: https://huggingface.co/google/medgemma-4b-it
HUGGINGFACE_TOKEN=your_token_here

# ── Model weights ─────────────────────────────────────────────────────────────
# Host path to downloaded model weights directory.
# Run: bash scripts/download_models.sh  to download.
MODEL_WEIGHTS_PATH=/path/to/model/weights

# ── Google Cloud (MedASR) ────────────────────────────────────────────────────
# Required for MedASR transcription via Google Cloud Speech-to-Text.
GCP_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Application ───────────────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── HIPAA audit log ───────────────────────────────────────────────────────────
AUDIT_LOG_PATH=/app/logs/audit.log

# ── Redis (task queue) ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Database (optional — for storing reports) ─────────────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/medgemma
