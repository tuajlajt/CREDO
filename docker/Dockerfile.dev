# Development Dockerfile
# Hot reload, source code mounted as volume (not copied), dev tools included.
# NOT for production use.

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 \
    libglib2.0-0 \
    libsndfile1 \
    ffmpeg \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
# Dev extras
RUN pip install --no-cache-dir pytest pytest-asyncio httpx ipython

# Source code mounted via docker-compose volume (not copied)
EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
